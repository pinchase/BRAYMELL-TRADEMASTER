# Django Settings
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=False

# Database (PostgreSQL)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://braymell_user:password@localhost:5432/braymell

# Cloudinary Configuration (for media storage)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Allowed Hosts (comma-separated for production)
# Example: braymell.onrender.com,braymell.com,www.braymell.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Configuration
# Domains that are allowed to make requests to your API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CSRF Trusted Origins
# Domains where forms can be submitted from
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
